<?xml version="1.0" encoding="utf-8"?>
<!--
  Disables both cloud backup (Google Auto Backup) and device-to-device transfer
  for the toxee app. The account profile (.tox blob) and message history are
  irreplaceable user data, and the legacy plain-prefs password hash + salt
  (cleaned up post-S1 review, but still present in older installs) must never
  leave the device through unattended backup. Users who want a portable copy
  of their identity should use the in-app export/import flow, which encrypts
  and lets them choose where the blob lands.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root"/>
        <exclude domain="file"/>
        <exclude domain="database"/>
        <exclude domain="sharedpref"/>
        <exclude domain="external"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root"/>
        <exclude domain="file"/>
        <exclude domain="database"/>
        <exclude domain="sharedpref"/>
        <exclude domain="external"/>
    </device-transfer>
</data-extraction-rules>
