{
  "id": "L3-group-pin-then-send",
  "suite": "group",
  "description": "Group pin + message activity COEXIST (hermetic, single-instance): create a group, pin it, then send a text into it — proving pinning does not break sending and sending does not drop the pin. Asserts BOTH the pin (pinnedConversations contains 'group_<gid>', exact) AND the persisted self-send (group history count 1 via conv='group_{{gid}}') on the LIVE group. Teardown unpins then leaves (quitGroup wipes history).",
  "requiresEchoPeer": false,
  "target": "3116CBE0974181B6EC4B32555413655B42C7456A93C6AF98A23E95127B587244",
  "steps": [
    { "action": "wait_for", "predicate": "state_equals", "field": "isConnected", "equals": true, "timeoutSecs": 30 },
    { "action": "create_group", "name": "L3gpinsend-{{nonce}}", "saveAs": "gid" },
    { "action": "wait_for", "predicate": "state_contains_item", "field": "knownGroups", "containsItem": "{{gid}}", "timeoutSecs": 15 },
    { "action": "set_pinned", "conversationId": "group_{{gid}}", "pinned": true },
    { "action": "wait_for", "predicate": "state_contains_item", "field": "pinnedConversations", "containsItem": "group_{{gid}}", "timeoutSecs": 10 },
    { "action": "send_group_text", "groupId": "{{gid}}", "text": "gpinsend-{{nonce}}" },
    { "action": "wait_for", "predicate": "message_exists", "conv": "group_{{gid}}", "text": "gpinsend-{{nonce}}", "isSelf": true, "timeoutSecs": 20 }
  ],
  "assertions": [
    { "type": "state", "field": "pinnedConversations", "containsItem": "group_{{gid}}" },
    { "type": "message_count_text", "conv": "group_{{gid}}", "text": "gpinsend-{{nonce}}", "isSelf": true, "equals": 1 },
    { "type": "message_field_contains", "conv": "group_{{gid}}", "text": "gpinsend-{{nonce}}", "isSelf": true, "field": "isPending", "contains": "false" }
  ],
  "teardown": [
    { "action": "set_pinned", "conversationId": "group_{{gid}}", "pinned": false },
    { "action": "leave_group", "groupId": "{{gid}}" }
  ]
}
