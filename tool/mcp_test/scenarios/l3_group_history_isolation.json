{
  "id": "L3-group-history-isolation",
  "suite": "group",
  "description": "Per-group history ISOLATION (hermetic, single-instance): create TWO groups, send a text into group A only, and prove the message lands in A's history (count 1) but NOT in B's (count 0). Guards against group history being keyed by a shared/empty bucket — a regression that would cross-contaminate group conversations. Reads each group's history via conv='group_{{gidA}}' / conv='group_{{gidB}}'. Asserts on the LIVE groups; both leaves deferred to teardown (quitGroup wipes group history).",
  "requiresEchoPeer": false,
  "target": "3116CBE0974181B6EC4B32555413655B42C7456A93C6AF98A23E95127B587244",
  "steps": [
    { "action": "wait_for", "predicate": "state_equals", "field": "isConnected", "equals": true, "timeoutSecs": 30 },
    { "action": "create_group", "name": "L3gisoA-{{nonce}}", "saveAs": "gidA" },
    { "action": "create_group", "name": "L3gisoB-{{nonce}}", "saveAs": "gidB" },
    { "action": "wait_for", "predicate": "state_contains_item", "field": "knownGroups", "containsItem": "{{gidA}}", "timeoutSecs": 15 },
    { "action": "wait_for", "predicate": "state_contains_item", "field": "knownGroups", "containsItem": "{{gidB}}", "timeoutSecs": 15 },
    { "action": "send_group_text", "groupId": "{{gidA}}", "text": "giso-{{nonce}}" },
    { "action": "wait_for", "predicate": "message_exists", "conv": "group_{{gidA}}", "text": "giso-{{nonce}}", "isSelf": true, "timeoutSecs": 20 }
  ],
  "assertions": [
    { "type": "message_count_text", "conv": "group_{{gidA}}", "text": "giso-{{nonce}}", "isSelf": true, "equals": 1 },
    { "type": "message_field_contains", "conv": "group_{{gidA}}", "text": "giso-{{nonce}}", "isSelf": true, "field": "isPending", "contains": "false" },
    { "type": "message_count_text", "conv": "group_{{gidB}}", "text": "giso-{{nonce}}", "isSelf": true, "equals": 0 }
  ],
  "teardown": [
    { "action": "leave_group", "groupId": "{{gidA}}" },
    { "action": "leave_group", "groupId": "{{gidB}}" }
  ]
}
