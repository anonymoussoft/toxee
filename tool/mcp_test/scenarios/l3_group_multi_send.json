{
  "id": "L3-group-multi-send",
  "suite": "group",
  "description": "Group BURST send / NO-LOSS (hermetic, single-instance): create a group, fire three DISTINCT texts back-to-back (no inter-send wait), settle all three (wait_for each), and prove each persists EXACTLY ONCE in the group's LOCAL history. equals:1 per text catches per-message LOSS (would be 0) or accidental DUPLICATION (would be 2) under rapid back-to-back sends. Scope (honest): this exercises the CONNECTED direct-append path of FfiChatService.sendGroupText (synchronous _appendHistory), NOT the offline-queue drain path — so it is the burst-persistence analog of l3_multi_send (S64 burst half), not a test of the offline group drain. Asserts on the LIVE group via conv='group_{{gid}}'; leave deferred to teardown (quitGroup wipes group history).",
  "requiresEchoPeer": false,
  "target": "3116CBE0974181B6EC4B32555413655B42C7456A93C6AF98A23E95127B587244",
  "steps": [
    { "action": "wait_for", "predicate": "state_equals", "field": "isConnected", "equals": true, "timeoutSecs": 30 },
    { "action": "create_group", "name": "L3gburst-{{nonce}}", "saveAs": "gid" },
    { "action": "wait_for", "predicate": "state_contains_item", "field": "knownGroups", "containsItem": "{{gid}}", "timeoutSecs": 15 },
    { "action": "send_group_text", "groupId": "{{gid}}", "text": "gb1-{{nonce}}" },
    { "action": "send_group_text", "groupId": "{{gid}}", "text": "gb2-{{nonce}}" },
    { "action": "send_group_text", "groupId": "{{gid}}", "text": "gb3-{{nonce}}" },
    { "action": "wait_for", "predicate": "message_exists", "conv": "group_{{gid}}", "text": "gb1-{{nonce}}", "isSelf": true, "timeoutSecs": 20 },
    { "action": "wait_for", "predicate": "message_exists", "conv": "group_{{gid}}", "text": "gb2-{{nonce}}", "isSelf": true, "timeoutSecs": 20 },
    { "action": "wait_for", "predicate": "message_exists", "conv": "group_{{gid}}", "text": "gb3-{{nonce}}", "isSelf": true, "timeoutSecs": 20 }
  ],
  "assertions": [
    { "type": "message_count_text", "conv": "group_{{gid}}", "text": "gb1-{{nonce}}", "isSelf": true, "equals": 1 },
    { "type": "message_count_text", "conv": "group_{{gid}}", "text": "gb2-{{nonce}}", "isSelf": true, "equals": 1 },
    { "type": "message_count_text", "conv": "group_{{gid}}", "text": "gb3-{{nonce}}", "isSelf": true, "equals": 1 },
    { "type": "message_field_contains", "conv": "group_{{gid}}", "text": "gb1-{{nonce}}", "isSelf": true, "field": "isPending", "contains": "false" }
  ],
  "teardown": [
    { "action": "leave_group", "groupId": "{{gid}}" }
  ]
}
